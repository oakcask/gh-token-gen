{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "customManagers:githubActionsVersions",
    "helpers:pinGitHubActionDigests"
  ],
  "prConcurrentLimit": 1,
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "matchDepNames": [
        "/^wasm-actions$/",
        "/^wasm-actions-/"
      ],
      "groupName": "wasm-actions monorepo"
    },
    {
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true
    },
    {
      "matchDepTypes":[
        "action"
      ],
      "matchCurrentAge": "> 5 days",
      "automerge": true
    }
  ],
  "rangeStrategy": "bump"
}
